-- ============================================================
-- 다문화가족 모자보건 통합관리 DB — 시드 데이터
-- 생성일: 2026-05-09
-- 재실행 안전 (DROP TABLE IF EXISTS 사용)
-- ============================================================

DROP TABLE IF EXISTS growth_records CASCADE;
DROP TABLE IF EXISTS vaccinations   CASCADE;
DROP TABLE IF EXISTS visits         CASCADE;
DROP TABLE IF EXISTS clinics        CASCADE;
DROP TABLE IF EXISTS patients       CASCADE;

CREATE TABLE clinics (
    clinic_id      SERIAL       PRIMARY KEY,
    name           VARCHAR(100) NOT NULL,
    region         VARCHAR(200) NOT NULL,
    facility_grade VARCHAR(20)  NOT NULL,
    staff_count    INT          NOT NULL
);
COMMENT ON TABLE  clinics IS '수도권 다문화 밀집지역 보건소 및 다문화가족지원센터';
COMMENT ON COLUMN clinics.name           IS '시설명 (예: 안산시보건소, 시흥다문화가족지원센터)';
COMMENT ON COLUMN clinics.region         IS '소재 행정구역 (도/시/구/동)';
COMMENT ON COLUMN clinics.facility_grade IS '시설 등급. 보건소: 1급/2급/3급, 지원센터: 센터';
COMMENT ON COLUMN clinics.staff_count    IS '의료진 및 상담사 총 인원수';

CREATE TABLE patients (
    patient_id        SERIAL       PRIMARY KEY,
    name              VARCHAR(100) NOT NULL,
    gender            CHAR(1)      NOT NULL,
    birth_date        DATE         NOT NULL,
    mother_id         INT          REFERENCES patients(patient_id),
    nationality       VARCHAR(50)  NOT NULL,
    residence_dong    VARCHAR(100) NOT NULL,
    registration_date DATE         NOT NULL
);
COMMENT ON TABLE  patients IS '결혼이주여성(어머니)과 다문화 영유아(자녀)의 통합 환자 정보. 모-자 관계는 mother_id 셀프참조로 표현';
COMMENT ON COLUMN patients.name              IS '환자 이름. 어머니는 출신국 원어 표기, 자녀는 한국 이름';
COMMENT ON COLUMN patients.gender            IS 'M=남성, F=여성. 결혼이주여성은 모두 F';
COMMENT ON COLUMN patients.mother_id         IS '자녀의 경우 어머니의 patient_id 를 참조. 어머니 본인은 NULL';
COMMENT ON COLUMN patients.nationality       IS '출신국. 어머니는 베트남/중국/필리핀/캄보디아/태국/일본/몽골 중 하나, 자녀는 한국';
COMMENT ON COLUMN patients.residence_dong    IS '거주 동(읍/면). 다문화 밀집지역: 원곡동/선부동/정왕본동/정왕1동/향남읍';
COMMENT ON COLUMN patients.registration_date IS '시스템 등록일';

CREATE TABLE visits (
    visit_id    SERIAL       PRIMARY KEY,
    patient_id  INT          NOT NULL REFERENCES patients(patient_id),
    clinic_id   INT          NOT NULL REFERENCES clinics(clinic_id),
    visit_date  DATE         NOT NULL,
    visit_type  VARCHAR(20)  NOT NULL,
    note        TEXT
);
COMMENT ON TABLE  visits IS '환자의 보건소·지원센터 방문 기록 (산전검진/출산/산후검진/영유아검진/예방접종/일반진료)';
COMMENT ON COLUMN visits.visit_type IS '방문유형. 가능한 값: 산전검진(임산부), 출산, 산후검진, 영유아검진(5세미만), 예방접종, 일반진료. 산전검진 회차 수는 같은 환자의 visit_type=''산전검진'' COUNT 으로 산출';
COMMENT ON COLUMN visits.note       IS '방문 메모. 예방접종 visit 의 경우 ''DTaP 2차 접종'' 등 백신정보 포함';

CREATE TABLE vaccinations (
    vacc_id          SERIAL       PRIMARY KEY,
    patient_id       INT          NOT NULL REFERENCES patients(patient_id),
    visit_id         INT          NOT NULL REFERENCES visits(visit_id),
    vaccine_code     VARCHAR(10)  NOT NULL,
    dose_number      INT          NOT NULL,
    vaccinated_date  DATE         NOT NULL,
    lot_number       VARCHAR(50)  NOT NULL
);
COMMENT ON TABLE  vaccinations IS '한국 국가예방접종 표준에 따른 영유아 예방접종 기록';
COMMENT ON COLUMN vaccinations.vaccine_code IS '백신 표준코드. BCG=결핵, HepB=B형간염, DTaP=디프테리아·파상풍·백일해, IPV=폴리오, MMR=홍역·유행성이하선염·풍진';
COMMENT ON COLUMN vaccinations.dose_number  IS '회차. BCG 는 1회, HepB 는 1~2차, DTaP 는 1~3차, IPV 는 1~2차, MMR 은 1~2차';
COMMENT ON COLUMN vaccinations.lot_number   IS '백신 로트번호 (제조 배치 식별)';

CREATE TABLE growth_records (
    record_id        SERIAL       PRIMARY KEY,
    patient_id       INT          NOT NULL REFERENCES patients(patient_id),
    visit_id         INT          NOT NULL REFERENCES visits(visit_id),
    measure_date     DATE         NOT NULL,
    weight_kg        NUMERIC(5,2) NOT NULL,
    height_cm        NUMERIC(5,2) NOT NULL,
    muac_cm          NUMERIC(4,2),
    waz_score        NUMERIC(4,2) NOT NULL,
    nutrition_status VARCHAR(20)  NOT NULL
);
COMMENT ON TABLE  growth_records IS '5세 미만 영유아 성장·영양 측정 기록. WHO 표준 기반';
COMMENT ON COLUMN growth_records.muac_cm          IS '상완둘레 (Mid-Upper Arm Circumference, cm). 6개월 이상에서 측정. WHO 기준: 정상≥12.5, 중등도급성영양실조 11.5~12.4, 심한급성영양실조<11.5';
COMMENT ON COLUMN growth_records.waz_score        IS 'Weight-for-Age Z-score (연령별체중 Z점수). WHO 기준: 정상≥-2, 중등도저체중 -3~-2, 심한저체중<-3';
COMMENT ON COLUMN growth_records.nutrition_status IS '영양상태 분류. 가능한 값: 정상, 중등도저체중, 심한저체중. waz_score 기반 자동분류된 결과';

